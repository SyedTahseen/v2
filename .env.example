# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: The default Gemini model to use for transcription and audio analysis (e.g. gemini-3.5-flash)
GEMINI_MODEL="gemini-3.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_USERNAME: Set the username for the Admin Transcript & Timestamp Curator Portal
ADMIN_USERNAME="admin"

# ADMIN_PASSWORD: Set the secure password for the Admin Transcript & Timestamp Curator Portal
ADMIN_PASSWORD="password123"

# PODCAST_RSS_URL: The RSS feed URL for the urology/sexual health podcast
PODCAST_RSS_URL="https://feeds.megaphone.fm/renamalikmd"

# MONGODB_URI: Stable, remote MongoDB connection string (e.g., mongodb+srv://...)
MONGODB_URI="your_mongodb_uri_here"

# YOUTUBE_API_KEY: Secure YouTube Data API v3 key to show subscriber counts & video grids
YOUTUBE_API_KEY=""

# YOUTUBE_CHANNEL_HANDLE: Optional override for the YouTube Channel handle (defaults to @renamalikmd)
YOUTUBE_CHANNEL_HANDLE="@renamalikmd"

# DELIRIUS_API_BASE: Optional base URL for external google search and youtube search endpoints (e.g. https://api.delirius.store)
DELIRIUS_API_BASE="https://api.delirius.store"


