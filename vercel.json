{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/episode/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api/|assets/|static/|favicon.ico|index.html).*)$",
      "destination": "/index.html"
    }
  ]
}
